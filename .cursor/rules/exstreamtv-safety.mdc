## RULE 15 — Caches: Always Include TTL (LL-019)

    import time as _t
    _cache_loaded_at: float = 0.0
    _CACHE_TTL: int = 300

    def _load_cache(force: bool = False) -> None:
        global _cache_loaded_at
        if not force and (_t.monotonic() - _cache_loaded_at) < _CACHE_TTL:
            return
        # ... reload credentials ...
        _cache_loaded_at = _t.monotonic()

