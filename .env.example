# Copy to ".env" in this folder and fill in values. ".env" is gitignored.
# Used by: scripts/publish_confluence_wiki_tree.py, publish_confluence_mirror.py
# MCP (mcp-atlassian) also needs CONFLUENCE_API_TOKEN in your shell or Cursor env.

CONFLUENCE_USER=you@example.com
CONFLUENCE_API_TOKEN=

# Optional
# CONFLUENCE_BASE_URL=https://exstreamtv2.atlassian.net
# CONFLUENCE_SPACE_KEY=ESTV
# CONFLUENCE_ROOT_PAGE_ID=   # omit to auto-reuse existing "EXStreamTV" page in the space
# CONFLUENCE_PARENT_PAGE_ID=
